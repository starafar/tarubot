# Ignore files with the extension ".pnp.*"
# These files are typically generated by Yarn's Plug'n'Play (PnP) feature and are not required to be tracked in version control.

.pnp.*

# The "yarn" directory contains various files and directories related to Yarn package manager.
# Most aren't needed.

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Ignore the "node_modules" directory
# This contains project dependencies installed by npm/yarn, which will be installed when
# the bot owner runs "npm install" or "yarn install".

node_modules

# Ignore the ".editorconfig" file
# The ".editorconfig" file contains editor settings and preferences, such as indentation style.

.editorconfig

# Ignore the ".venv" directory. Not even sure why this is getting created.

.venv

# Ignore the ".vscode" directory
# The ".vscode" directory contains configuration files specific to Visual Studio Code editor.

.vscode

# The ".env" file contains local configuration settings specific to the environment
# and contains sensitive information like API keys or database credentials.
# The ".env.example" file is the template for the local configuration.

.env
!.env.example

# Ignore the "logs" directory
# The "logs" directory contains log files generated by the bot during runtime.

logs
